YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_TITLE_REGEX=.*
YOUTUBE_ACTIVE_WINDOW_UTC=10:00-20:00
YOUTUBE_POLL_INTERVAL=600

KICK_KEY=your-kick-stream-key
KICK_URL=rtmps://fa723fc1b171.global-contribute.live-video.net:443/app

HLS_ORIGIN_PORT=8080
LOCAL_HLS_URL=http://hls-origin/live/index.m3u8
LOCAL_HLS_URL_GLUETUN=http://host.docker.internal:8080/live/index.m3u8

KICK_TRANSCODE_MODE=transcode
VIDEO_BITRATE=7500k
AUDIO_BITRATE=160k
FPS=60
GOP=120
PRESET=veryfast
HWENC_MODE=software
VAAPI_DEVICE=/dev/dri/renderD128

YTDLP_FORMAT=best[protocol^=m3u8][height<=720]/best[height<=720]/best
